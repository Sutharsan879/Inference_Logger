# MongoDB (required)
# Local:
DATABASE_URL=mongodb://127.0.0.1:27017/inference_logs
# Atlas (production / Vercel):
# DATABASE_URL=mongodb+srv://USER:PASS@cluster.mongodb.net/inference_logs?retryWrites=true&w=majority

# Backend (optional local Express — Vercel uses Next.js /api routes)
PORT=8000
CORS_ORIGINS=http://localhost:3000
MOCK_LLM=false
INGESTION_MODE=queue
MAX_CONTEXT_MESSAGES=20

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Frontend — leave empty on Vercel (same-origin /api). Local with separate backend:
# NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=
